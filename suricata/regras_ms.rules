alert tcp $EXTERNAL_NET any -> $HOME_NET 22   (msg:"MS AUTH EXT: Brute force SSH de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 10, seconds 30; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900069; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"MS AUTH EXT: Brute force RDP de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 10, seconds 60; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900070; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 21   (msg:"MS AUTH EXT: Brute force FTP de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 10, seconds 60; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900071; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 445  (msg:"MS AUTH EXT: Tentativas SMB de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 10, seconds 30; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900072; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 23   (msg:"MS AUTH EXT: Brute force Telnet de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 8, seconds 30; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900073; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 5985 (msg:"MS AUTH EXT: Brute force WinRM de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 8, seconds 60; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900074; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET [80,443,8080,8443] (msg:"MS AUTH EXT: Muitas tentativas web de origem externa"; flow:to_server; detection_filter:track by_src, count 30, seconds 30; classtype:web-application-attack; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900075; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET [1433,3306,5432,27017,6379] (msg:"MS AUTH EXT: Tentativas em banco de dados de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 5, seconds 30; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction inbound; sid:9900076; rev:1;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO C — MOVIMENTO LATERAL  (9900017–9900022)
# Cobre: $HOME_NET → $HOME_NET
