alert tcp $HOME_NET any -> $HOME_NET 3389 (msg:"MS AUTH: Possivel brute force RDP interno"; flow:to_server; flags:S; detection_filter:track by_src, count 25, seconds 60; classtype:attempted-admin; priority:1; metadata: moonshield yes, stage auth, direction internal; sid:9900010; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 21   (msg:"MS AUTH: Possivel brute force FTP interno"; flow:to_server; flags:S; detection_filter:track by_src, count 20, seconds 60; classtype:attempted-admin; priority:2; metadata: moonshield yes, stage auth, direction internal; sid:9900011; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 445  (msg:"MS AUTH/LATERAL: Muitas conexoes SMB internas"; flow:to_server; flags:S; detection_filter:track by_src, count 40, seconds 30; classtype:attempted-admin; priority:2; metadata: moonshield yes, stage auth, stage lateral, direction internal; sid:9900012; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 5985 (msg:"MS AUTH: Possivel brute force WinRM HTTP interno (5985)"; flow:to_server; flags:S; detection_filter:track by_src, count 20, seconds 60; classtype:attempted-admin; priority:2; metadata: moonshield yes, stage auth, direction internal; sid:9900013; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 5986 (msg:"MS AUTH: Possivel brute force WinRM HTTPS interno (5986)"; flow:to_server; flags:S; detection_filter:track by_src, count 20, seconds 60; classtype:attempted-admin; priority:2; metadata: moonshield yes, stage auth, direction internal; sid:9900014; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 23   (msg:"MS AUTH: Possivel brute force Telnet interno"; flow:to_server; flags:S; detection_filter:track by_src, count 15, seconds 30; classtype:attempted-admin; priority:2; metadata: moonshield yes, stage auth, direction internal; sid:9900015; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET [80,443,8080,8443] (msg:"MS AUTH: Muitas tentativas em servico web interno"; flow:to_server; detection_filter:track by_src, count 60, seconds 30; classtype:web-application-attack; priority:2; metadata: moonshield yes, stage auth, direction internal; sid:9900016; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO B2 — BRUTE FORCE EXTERNO  (9900069–9900076)
# Cobre: $EXTERNAL_NET → $HOME_NET  (ataques vindos de fora / outra rede)
