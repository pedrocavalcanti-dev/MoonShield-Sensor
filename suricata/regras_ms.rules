alert tcp $HOME_NET any -> $HOME_NET 135  (msg:"MS LATERAL: Pico de conexoes RPC (135) na LAN"; flow:to_server; detection_filter:track by_src, count 40, seconds 30; classtype:misc-activity; priority:2; metadata: moonshield yes, stage lateral, direction internal; sid:9900017; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 139  (msg:"MS LATERAL: Pico de NetBIOS/SMB (139) na LAN"; flow:to_server; detection_filter:track by_src, count 30, seconds 30; classtype:misc-activity; priority:3; metadata: moonshield yes, stage lateral, direction internal; sid:9900018; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 445  (msg:"MS LATERAL: Varredura SMB em muitos alvos (445 sweep)"; flow:to_server; detection_filter:track by_src, count 80, seconds 60; classtype:misc-activity; priority:2; metadata: moonshield yes, stage lateral, direction internal; sid:9900019; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 1433 (msg:"MS LATERAL/DB: Pico de tentativas MSSQL na LAN"; flow:to_server; detection_filter:track by_src, count 15, seconds 30; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage lateral, direction internal; sid:9900020; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 3306 (msg:"MS LATERAL/DB: Pico de tentativas MySQL na LAN"; flow:to_server; detection_filter:track by_src, count 15, seconds 30; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage lateral, direction internal; sid:9900021; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET 5432 (msg:"MS LATERAL/DB: Pico de tentativas PostgreSQL na LAN"; flow:to_server; detection_filter:track by_src, count 15, seconds 30; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage lateral, direction internal; sid:9900022; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO D — DNS / POLICY DNS  (9900023–9900032)
# Cobre: $HOME_NET → $EXTERNAL_NET
# ═════════════════════════════════════════════════════════════════════════════

alert udp $HOME_NET any -> [8.8.8.8,8.8.4.4] 53 (msg:"MS DNS POLICY: Bypass DNS - Google DNS (8.8.8.x)"; detection_filter:track by_src, count 3, seconds 60; classtype:policy-violation; priority:3; metadata: moonshield yes, tag bypass-dns; sid:9900023; rev:2;)
alert udp $HOME_NET any -> [1.1.1.1,1.0.0.1] 53 (msg:"MS DNS POLICY: Bypass DNS - Cloudflare (1.1.1.x)"; detection_filter:track by_src, count 3, seconds 60; classtype:policy-violation; priority:3; metadata: moonshield yes, tag bypass-dns; sid:9900024; rev:2;)
alert udp $HOME_NET any -> [9.9.9.9,149.112.112.112] 53 (msg:"MS DNS POLICY: Bypass DNS - Quad9 (9.9.9.x)"; detection_filter:track by_src, count 3, seconds 60; classtype:policy-violation; priority:3; metadata: moonshield yes, tag bypass-dns; sid:9900025; rev:2;)
alert udp $HOME_NET any -> $EXTERNAL_NET 53 (msg:"MS DNS: Volume alto de consultas DNS externas (possivel DGA)"; detection_filter:track by_src, count 120, seconds 60; classtype:misc-activity; priority:3; metadata: moonshield yes; sid:9900026; rev:2;)
alert udp $HOME_NET any -> $EXTERNAL_NET 53 (msg:"MS DNS: Alto volume DNS (verificar NXDOMAIN no painel)"; detection_filter:track by_src, count 200, seconds 60; classtype:misc-activity; priority:3; metadata: moonshield yes, tag nxdomain-candidate; sid:9900027; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a ip-api.com (descoberta de IP externo)"; dns.query; content:"ip-api.com"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900028; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a ifconfig.me (descoberta de IP externo)"; dns.query; content:"ifconfig.me"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900029; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a api.ipify.org (descoberta de IP externo)"; dns.query; content:"api.ipify.org"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900030; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a checkip.amazonaws.com (descoberta de IP externo)"; dns.query; content:"checkip.amazonaws.com"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900031; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a servico whatismyip"; dns.query; content:"whatismyip"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900032; rev:3;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Consulta a servico icanhazip"; dns.query; content:"icanhazip"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag external-ip-lookup; sid:9900059; rev:1;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO E — P2P / MINERACAO / POLICY  (9900033–9900038)
# Cobre: $HOME_NET → $EXTERNAL_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"MS POLICY: Trafego P2P BitTorrent (handshake)"; flow:to_server,established; content:"BitTorrent protocol"; depth:19; classtype:policy-violation; priority:3; metadata: moonshield yes, category p2p; sid:9900033; rev:2;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS POLICY: Requisicao HTTP para tracker BitTorrent"; flow:to_server,established; http.uri; content:"/announce"; nocase; classtype:policy-violation; priority:3; metadata: moonshield yes, category p2p; sid:9900034; rev:3;)
alert tcp $HOME_NET any -> $EXTERNAL_NET [3333,4444,5555,7777,9000,14444,45560] (msg:"MS POLICY: Possivel mineracao cripto (mining.subscribe)"; flow:to_server,established; content:"mining.subscribe"; nocase; classtype:policy-violation; priority:2; metadata: moonshield yes, category mining; sid:9900035; rev:2;)
alert tcp $HOME_NET any -> $EXTERNAL_NET [3333,4444,5555,7777,9000,14444,45560] (msg:"MS POLICY: Possivel mineracao cripto (mining.authorize)"; flow:to_server,established; content:"mining.authorize"; nocase; classtype:policy-violation; priority:2; metadata: moonshield yes, category mining; sid:9900036; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS POLICY: Consulta DNS pool mineracao (xmr)"; dns.query; content:"xmr"; nocase; classtype:policy-violation; priority:2; metadata: moonshield yes, category mining; sid:9900037; rev:3;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS POLICY: Consulta DNS pool mineracao (monero)"; dns.query; content:"monero"; nocase; classtype:policy-violation; priority:2; metadata: moonshield yes, category mining; sid:9900060; rev:1;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS POLICY: Consulta DNS pool mineracao (nicehash)"; dns.query; content:"nicehash"; nocase; classtype:policy-violation; priority:2; metadata: moonshield yes, category mining; sid:9900096; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET [9001,9030,9050,9051] (msg:"MS POLICY: Conexao para porta Tor"; flow:to_server,established; classtype:policy-violation; priority:3; metadata: moonshield yes, category proxy; sid:9900038; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO F — ANOMALIAS / BEACONING / BOT  (9900039–9900046)
# Cobre: $HOME_NET → $EXTERNAL_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"MS ANOMALIA: Muitas conexoes TCP externas (possivel bot)"; flow:to_server; flags:S; detection_filter:track by_src, count 300, seconds 60; classtype:misc-activity; priority:3; metadata: moonshield yes, tag bot; sid:9900039; rev:2;)
alert icmp $HOME_NET any -> $EXTERNAL_NET any (msg:"MS ANOMALIA: Volume alto de ICMP externo (possivel tunel ICMP)"; itype:8; detection_filter:track by_src, count 80, seconds 60; classtype:misc-activity; priority:3; metadata: moonshield yes, tag icmp-tunnel; sid:9900040; rev:2;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"MS ANOMALIA: TLS repetitivo (possivel beaconing)"; flow:to_server,established; detection_filter:track by_src, count 120, seconds 300; classtype:misc-activity; priority:3; metadata: moonshield yes, tag beaconing; sid:9900041; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS ANOMALIA: Consulta DNS frequente (possivel beaconing)"; detection_filter:track by_src, count 60, seconds 120; classtype:misc-activity; priority:3; metadata: moonshield yes, tag beaconing; sid:9900042; rev:2;)
alert tcp $HOME_NET any -> $EXTERNAL_NET [1337,4444,6667,6697,31337,9001,55553,54321,12345] (msg:"MS C2: Conexao para porta externa suspeita (C2/backdoor/IRC)"; flow:to_server,established; classtype:trojan-activity; priority:2; metadata: moonshield yes, category c2; sid:9900043; rev:2;)
# SID 9900044 removido (pcre UA vazio instavel entre versoes Suricata — detectar no Django via eve.json)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS SUSPEITO: Download de executavel (.exe) via HTTP"; flow:to_server,established; http.uri; content:".exe"; nocase; classtype:misc-activity; priority:2; metadata: moonshield yes, tag exe-download; sid:9900045; rev:2;)
# SID 9900046 (DGA pcre) — melhor detectar no Django via eve.json (dominio longo sem vogais)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO G — TLS / QUIC  (9900047–9900050)
# Cobre: $HOME_NET → $EXTERNAL_NET
# ═════════════════════════════════════════════════════════════════════════════

alert udp $HOME_NET any -> $EXTERNAL_NET 443 (msg:"MS TLS/QUIC: Trafego QUIC detectado (UDP/443)"; classtype:misc-activity; priority:4; metadata: moonshield yes, tag quic; sid:9900047; rev:2;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"MS TLS: SNI com subdomain numerico (indicativo suspeito)"; flow:to_server,established; tls.sni; pcre:"/^\\d{4,}\\./"; classtype:misc-activity; priority:2; metadata: moonshield yes, tag suspicious-sni; sid:9900048; rev:2;)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"MS TLS: Conexao TLS sem SNI (verificar no painel)"; flow:to_server,established; classtype:misc-activity; priority:3; metadata: moonshield yes, tag no-sni-candidate; sid:9900049; rev:2;)
alert udp $HOME_NET any -> $EXTERNAL_NET 443 (msg:"MS TLS/QUIC: Volume alto de QUIC - possivel bypass"; detection_filter:track by_src, count 200, seconds 60; classtype:misc-activity; priority:3; metadata: moonshield yes, tag quic-volume; sid:9900050; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO H — NMAP / OS FINGERPRINT INTERNO  (9900051–9900053)
# Cobre: $HOME_NET → $HOME_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Nmap NULL scan interno (sem flags TCP)"; flags:0; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, tag nmap, direction internal; sid:9900051; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Nmap XMAS scan interno (FIN+PSH+URG)"; flags:FPU; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, tag nmap, direction internal; sid:9900052; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Flag TCP anomala SYN+FIN interno (Nmap/OS fingerprint)"; flags:SF; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, tag nmap, direction internal; sid:9900053; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO I — DNS TUNNELING  (9900054–9900055)
# ═════════════════════════════════════════════════════════════════════════════

alert udp $HOME_NET any -> any 53 (msg:"MS DNS: Payload UDP/DNS muito grande (possivel DNS tunneling)"; dsize:>150; classtype:misc-activity; priority:2; metadata: moonshield yes, tag dns-tunnel; sid:9900054; rev:2;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS DNS: Label longo em consulta (possivel DNS tunneling)"; dns.query; pcre:"/[a-z0-9\\-]{50,}\\./i"; classtype:misc-activity; priority:2; metadata: moonshield yes, tag dns-tunnel; sid:9900055; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO J — HOST SWEEP  (9900056–9900058)
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS LATERAL: Host sweep interno agressivo (muitos destinos)"; flow:to_server; flags:S; detection_filter:track by_src, count 50, seconds 10; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, stage lateral, direction internal; sid:9900056; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Host sweep externo agressivo"; flow:to_server; flags:S; detection_filter:track by_src, count 30, seconds 10; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900057; rev:1;)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Ping sweep externo agressivo"; itype:8; detection_filter:track by_src, count 15, seconds 10; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900058; rev:1;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO K — EXPLOITS / VULNERABILIDADES CONHECIDAS  (9900077–9900086)
# Cobre: $EXTERNAL_NET → $HOME_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"MS EXPLOIT EXT: Possivel EternalBlue/SMB exploit de origem externa"; flow:to_server,established; content:"|00 00 00 00 ff 53 4d 42|"; depth:9; classtype:attempted-admin; priority:1; metadata: moonshield yes, tag exploit, tag eternalblue, direction inbound; sid:9900077; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80  (msg:"MS EXPLOIT EXT: Possivel SQL Injection via HTTP"; flow:to_server,established; http.uri; pcre:"/(?:union.*select|select.*from|insert.*into|drop.*table|exec.*xp_)/i"; classtype:web-application-attack; priority:1; metadata: moonshield yes, tag sqli, direction inbound; sid:9900078; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80  (msg:"MS EXPLOIT EXT: Possivel XSS via HTTP"; flow:to_server,established; http.uri; pcre:"/<script[^>]*>/i"; classtype:web-application-attack; priority:2; metadata: moonshield yes, tag xss, direction inbound; sid:9900079; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 80  (msg:"MS EXPLOIT EXT: Possivel Path Traversal via HTTP"; flow:to_server,established; http.uri; content:"../"; classtype:web-application-attack; priority:2; metadata: moonshield yes, tag path-traversal, direction inbound; sid:9900080; rev:1;)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"MS EXPLOIT EXT: Possivel shell command injection via HTTP (whoami)"; flow:to_server,established; http.uri; content:"whoami"; nocase; classtype:web-application-attack; priority:1; metadata: moonshield yes, tag cmdi, direction inbound; sid:9900081; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22  (msg:"MS EXPLOIT EXT: Conexao SSH de IP externo desconhecido"; flow:to_server,established; detection_filter:track by_src, count 3, seconds 60; classtype:attempted-admin; priority:2; metadata: moonshield yes, tag ssh-external, direction inbound; sid:9900082; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (msg:"MS EXPLOIT EXT: Conexao RDP de origem externa"; flow:to_server,established; detection_filter:track by_src, count 3, seconds 60; classtype:attempted-admin; priority:1; metadata: moonshield yes, tag rdp-external, direction inbound; sid:9900083; rev:1;)
alert udp $EXTERNAL_NET any -> $HOME_NET 53  (msg:"MS EXPLOIT EXT: Volume alto de consultas DNS de origem externa (possivel amplificacao)"; detection_filter:track by_src, count 50, seconds 10; classtype:misc-activity; priority:2; metadata: moonshield yes, tag dns-amplification, direction inbound; sid:9900084; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS EXPLOIT EXT: Flag TCP SYN+FIN de origem externa (probe)"; flags:SF; classtype:attempted-recon; priority:1; metadata: moonshield yes, tag nmap, direction inbound; sid:9900085; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET [6379,27017,9200,5601,2375] (msg:"MS EXPLOIT EXT: Tentativa de acesso a servico exposto (Redis/Mongo/ES/Docker)"; flow:to_server; flags:S; classtype:attempted-admin; priority:1; metadata: moonshield yes, tag exposed-service, direction inbound; sid:9900086; rev:1;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO L — EXFILTRACAO / C2 EXTERNO  (9900091–9900098)
# Cobre: $HOME_NET → $EXTERNAL_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"MS EXFIL: Volume alto de dados saindo (possivel exfiltracao)"; flow:to_server,established; detection_filter:track by_src, count 500, seconds 60; classtype:misc-activity; priority:2; metadata: moonshield yes, tag exfil; sid:9900091; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS EXFIL: Requisicao POST HTTP saindo (possivel exfiltracao)"; flow:to_server,established; http.method; content:"POST"; classtype:misc-activity; priority:2; metadata: moonshield yes, tag exfil; sid:9900092; rev:4;)
alert dns $HOME_NET any -> $EXTERNAL_NET any (msg:"MS C2: Consulta DNS para dominio .onion via DNS (Tor)"; dns.query; content:".onion"; nocase; classtype:trojan-activity; priority:1; metadata: moonshield yes, tag tor, category c2; sid:9900093; rev:1;)
alert tcp $HOME_NET any -> $EXTERNAL_NET [4444,5555,8888,9999,1234,6666] (msg:"MS C2: Conexao para porta C2 comum de origem interna"; flow:to_server,established; classtype:trojan-activity; priority:1; metadata: moonshield yes, category c2; sid:9900094; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS C2: User-Agent sqlmap detectado"; flow:to_server,established; http.user_agent; content:"sqlmap"; nocase; classtype:trojan-activity; priority:1; metadata: moonshield yes, tag attack-tool; sid:9900095; rev:2;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS C2: User-Agent nikto detectado"; flow:to_server,established; http.user_agent; content:"Nikto"; nocase; classtype:trojan-activity; priority:1; metadata: moonshield yes, tag attack-tool; sid:9900097; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"MS C2: User-Agent masscan detectado"; flow:to_server,established; http.user_agent; content:"masscan"; nocase; classtype:trojan-activity; priority:1; metadata: moonshield yes, tag attack-tool; sid:9900098; rev:1;)

# 9900099–9900100 reservados para expansão
# 9900101–9900120 reservados para regras de ambiente específico

