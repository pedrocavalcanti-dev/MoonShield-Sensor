# =============================================================================
# MOONSHIELD — Ruleset v2.1
# Arquivo destino: /var/lib/suricata/rules/moonshield/ms.rules
#
# SID range reservado MOONSHIELD: 9900001 – 9900120
#
# v2.1 — Todos os prefixos renomeados JG → MS (MoonShield)
#
# v2.0 — Cobertura completa:
#   - $HOME_NET → $HOME_NET     (movimento lateral / interno)
#   - $EXTERNAL_NET → $HOME_NET (ataques vindos de fora / outra rede)
#   - $HOME_NET → $EXTERNAL_NET (exfiltração / policy)
#
# Observações:
# - NXDOMAIN em massa: implementado no Django via eve.json
# - ARP / novos dispositivos: implementado no monitoramento.py via scapy
# - TLS sem SNI: detectado no Django via eve.json (tls.sni ausente)
# =============================================================================


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO A — RECON / VARREDURA INTERNA  (9900001–9900008)
# Cobre: $HOME_NET → $HOME_NET
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Possivel port scan SYN interno (muitas portas)"; flow:to_server; flags:S; detection_filter:track by_src, count 40, seconds 10; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, direction internal; sid:9900001; rev:2;)
alert icmp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Possivel ping sweep ICMP na rede interna"; itype:8; detection_filter:track by_src, count 30, seconds 10; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage recon, direction internal; sid:9900002; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Possivel host sweep TCP interno (muitos destinos)"; flow:to_server; detection_filter:track by_src, count 120, seconds 30; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage recon, direction internal; sid:9900003; rev:2;)
alert udp $HOME_NET any -> $HOME_NET 161 (msg:"MS RECON: Varredura SNMP (UDP/161) na rede interna"; detection_filter:track by_src, count 12, seconds 10; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, direction internal; sid:9900004; rev:2;)
alert tcp $HOME_NET any -> $HOME_NET [80,443,8080,8443,9000,9090] (msg:"MS RECON: Varredura de paineis web admin na rede interna"; flow:to_server; flags:S; detection_filter:track by_src, count 30, seconds 20; classtype:web-application-attack; priority:2; metadata: moonshield yes, stage recon, direction internal; sid:9900005; rev:2;)
alert udp $HOME_NET any -> $HOME_NET any (msg:"MS RECON: Scan UDP para muitas portas internas"; detection_filter:track by_src, count 60, seconds 20; classtype:attempted-recon; priority:3; metadata: moonshield yes, stage recon, direction internal; sid:9900006; rev:2;)
# 9900007 reservado (ARP — monitoramento.py)
alert tcp $HOME_NET any -> $HOME_NET [31337,4444,1337,12345,54321] (msg:"MS RECON: Conexao para porta alta suspeita na LAN (fingerprinting)"; flow:to_server; flags:S; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, direction internal; sid:9900008; rev:2;)


# ═════════════════════════════════════════════════════════════════════════════
# GRUPO A2 — RECON / VARREDURA EXTERNA  (9900061–9900068)
# Cobre: $EXTERNAL_NET → $HOME_NET  (ataques vindos de fora)
# ═════════════════════════════════════════════════════════════════════════════

alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Port scan SYN de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 40, seconds 10; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900061; rev:1;)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Ping sweep ICMP de origem externa"; itype:8; detection_filter:track by_src, count 20, seconds 10; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, direction inbound; sid:9900062; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Host sweep TCP de origem externa"; flow:to_server; detection_filter:track by_src, count 80, seconds 30; classtype:attempted-recon; priority:2; metadata: moonshield yes, stage recon, direction inbound; sid:9900063; rev:1;)
alert udp $EXTERNAL_NET any -> $HOME_NET 161 (msg:"MS RECON EXT: Varredura SNMP de origem externa"; detection_filter:track by_src, count 8, seconds 10; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900064; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET [80,443,8080,8443,9000,9090] (msg:"MS RECON EXT: Varredura de paineis web admin de origem externa"; flow:to_server; flags:S; detection_filter:track by_src, count 20, seconds 20; classtype:web-application-attack; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900065; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET [31337,4444,1337,12345,54321] (msg:"MS RECON EXT: Conexao para porta suspeita de origem externa"; flow:to_server; flags:S; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, direction inbound; sid:9900066; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Nmap NULL scan de origem externa (sem flags TCP)"; flags:0; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, tag nmap, direction inbound; sid:9900067; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"MS RECON EXT: Nmap XMAS scan de origem externa (FIN+PSH+URG)"; flags:FPU; classtype:attempted-recon; priority:1; metadata: moonshield yes, stage recon, tag nmap, direction inbound; sid:9900068; rev:1;)


